# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1

# Langfuse local Docker defaults. Create project keys in http://localhost:3000.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# Workflow safety and defaults
WORKFLOW_ENVIRONMENT=local-dev
WORKFLOW_MAX_TEST_RETRIES=2
WORKFLOW_ALLOWED_COMMANDS=pytest,npm test,npm run test,python -m pytest,python app.py --check
WORKSPACE_PATH=examples/demo_project
TEST_COMMAND=python -m pytest
DEPLOY_COMMAND=python app.py --check
